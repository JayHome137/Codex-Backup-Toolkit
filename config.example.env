# Copy this file to config.env, edit the values, then run:
#   source ./config.env
#   ./scripts/codexbackup.sh

# Tool identity
CODEX_BACKUP_PROFILE=codex
# Supported values: local, smb, webdav, rclone.
CODEX_BACKUP_TARGET=local

# Backup behavior
CODEX_BACKUP_REMOTE_DIR=codex-backups
CODEX_BACKUP_TOOLKIT_REMOTE_DIR=codex-restore-toolkit
CODEX_BACKUP_SPOOL_DIR="$HOME/Library/Application Support/CodexBackupToolkit/spool"
CODEX_BACKUP_INTERVAL_DAYS=3
CODEX_BACKUP_RETENTION_COUNT=0
CODEX_BACKUP_RETENTION_DAYS=0
# Remote retention is opt-in. When set to 1, WebDAV/rclone keep the newest
# CODEX_BACKUP_RETENTION_COUNT archives and delete older remote artifacts.
CODEX_BACKUP_REMOTE_RETENTION=0

# Local-authoritative consistency check. Disabled by default.
# When enabled, scheduled backups run a consistency check first. Local data is
# always authoritative; if the latest backup differs, a new timestamped backup
# is created and existing retention settings are applied.
CODEX_BACKUP_SYNC_ENABLED=0
CODEX_BACKUP_SYNC_CHECK_INTERVAL_HOURS=24
CODEX_BACKUP_SYNC_MIN_BACKUP_INTERVAL_HOURS=24

# Optional archive encryption. Requires age: https://age-encryption.org
CODEX_BACKUP_ENCRYPT=0
CODEX_BACKUP_ENCRYPTION=age
# CODEX_BACKUP_AGE_RECIPIENT=age1example...
# CODEX_BACKUP_AGE_RECIPIENT_FILE=/path/to/recipients.txt
# Restore encrypted archives with CODEX_BACKUP_AGE_IDENTITY=/path/to/identity.txt

# local target
CODEX_BACKUP_LOCAL_DIR="$HOME/CodexBackups"

# smb target
CODEX_BACKUP_SMB_HOST=nas.example.local
CODEX_BACKUP_SMB_USER=backup-user
CODEX_BACKUP_SMB_SHARE=CodexBackup
CODEX_BACKUP_SMB_MOUNT="$HOME/Volumes/CodexBackup"
CODEX_BACKUP_KEYCHAIN_SERVICE=codexbackup-smb
CODEX_BACKUP_KEYCHAIN_ACCOUNT="backup-user@nas.example.local/CodexBackup"
# Optional one-run password override: export CODEX_BACKUP_PASSWORD before running.

# webdav target. The script uses curl and can read the password from Keychain.
CODEX_BACKUP_WEBDAV_URL="https://webdav.example.com/remote.php/dav/files/user/CodexBackup"
CODEX_BACKUP_WEBDAV_USER=backup-user
CODEX_BACKUP_WEBDAV_KEYCHAIN_SERVICE=codexbackup-webdav
CODEX_BACKUP_WEBDAV_KEYCHAIN_ACCOUNT=backup-user@webdav.example.com
# Optional one-run password override: export CODEX_BACKUP_WEBDAV_PASSWORD before running.

# rclone target. Configure the remote with `rclone config` first.
CODEX_BACKUP_RCLONE_REMOTE="gdrive:CodexBackup"
