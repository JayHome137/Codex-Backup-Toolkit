{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexBackup",
  "version": "0.36.2",
  "identifier": "com.jayhome137.codexbackup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Utility",
    "icon": ["icons/icon.ico"],
    "shortDescription": "CodexBackup Windows preview",
    "longDescription": "CodexBackup Windows preview package. Signing, install-after-download smoke, remote target validation, and real restore execution are still pending.",
    "resources": {
      "../../helper": "toolkit/helper",
      "../../scripts": "toolkit/scripts",
      "../../config.example.env": "toolkit/config.example.env",
      "../../examples": "toolkit/examples"
    }
  }
}
