{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexBackup",
  "version": "0.36.5",
  "identifier": "com.jayhome137.codexbackup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodexBackup",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": {
      "../../helper/actions.mjs": "toolkit/helper/actions.mjs",
      "../../helper/allowlist.mjs": "toolkit/helper/allowlist.mjs",
      "../../helper/automation-status.mjs": "toolkit/helper/automation-status.mjs",
      "../../helper/config-store.mjs": "toolkit/helper/config-store.mjs",
      "../../helper/executor.mjs": "toolkit/helper/executor.mjs",
      "../../helper/history-store.mjs": "toolkit/helper/history-store.mjs",
      "../../helper/keychain.mjs": "toolkit/helper/keychain.mjs",
      "../../helper/server.mjs": "toolkit/helper/server.mjs",
      "../../scripts": "toolkit/scripts",
      "../../config.example.env": "toolkit/config.example.env",
      "../../examples": "toolkit/examples"
    },
    "shortDescription": "Codex backup desktop toolkit",
    "longDescription": "CodexBackup packages the local backup helper and GUI into a desktop utility."
  }
}
