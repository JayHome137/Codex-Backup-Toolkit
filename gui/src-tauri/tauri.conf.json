{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodexBackup",
  "version": "0.8.0",
  "identifier": "com.jayhome137.codexbackup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodexBackup",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "shortDescription": "Codex backup desktop toolkit",
    "longDescription": "CodexBackup packages the local backup helper and GUI into a desktop utility."
  }
}
