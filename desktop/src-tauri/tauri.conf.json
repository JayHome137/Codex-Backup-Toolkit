{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLB",
  "version": "0.1.0",
  "identifier": "com.jay.clb",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "CLB",
        "width": 980,
        "height": 720,
        "minWidth": 860,
        "minHeight": 620,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "CLB local Codex backup",
    "longDescription": "CLB backs up local Codex state and Documents/Codex to a user-selected local folder."
  }
}
